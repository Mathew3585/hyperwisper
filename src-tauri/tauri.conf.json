{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hyperwisper",
  "version": "0.1.0",
  "identifier": "com.hyperwisper.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hyperwisper",
        "url": "index.html",
        "width": 980,
        "height": 700,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "visible": false,
        "center": true
      },
      {
        "label": "overlay",
        "title": "Hyperwisper Overlay",
        "url": "overlay.html",
        "width": 520,
        "height": 140,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "resizable": false,
        "visible": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: asset: http://asset.localhost; font-src 'self' data:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost asset: http://asset.localhost; script-src 'self'"
    }
  },
  "bundle": {
    "active": false,
    "publisher": "Mathew Simon",
    "copyright": "Copyright © 2026 Mathew Simon",
    "category": "Productivity",
    "shortDescription": "Local voice-to-text dictation",
    "longDescription": "Voice dictation that runs entirely on your PC. Press a shortcut, speak, and your words appear wherever your cursor is. No subscription, no cloud, no compromise on privacy.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
